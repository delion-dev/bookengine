{
  "$schema": "https://schema.tauri.app/core/schema/capability",
  "identifier": "default",
  "description": "Default capability for BookEngine desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://localhost:8000/**" }]
    },
    "dialog:default"
  ]
}
