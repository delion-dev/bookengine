# Core Engine Google model runtime
# Copy this file to .env and replace the placeholder values.

# ── BookEngine App (frontend/.env.local) ─────────────────────────────────────
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=XXXXXXXXXX
# BOOKENGINE_LICENSE_SECRET=your-secret-here
# ─────────────────────────────────────────────────────────────────────────────

VERTEX_ENABLE_LIVE_CALLS=false
MODEL_GATEWAY_PROVIDER=vertex_ai
# MODEL_GATEWAY_PROVIDER=gemini_api

# Engine-standard identity
# - optional in vertex_ai express/api_key mode
# - required in vertex_ai standard/access_token mode
VERTEX_PROJECT_ID=your-google-cloud-project-id
VERTEX_REGION=global

# Auth strategy
# - vertex_ai + api_key: Vertex express-mode endpoint
# - gemini_api + api_key: Gemini API direct endpoint
# - vertex_ai + access_token: full Vertex REST endpoint with project/location
VERTEX_AUTH_MODE=api_key
VERTEX_API_KEY=your-vertex-express-mode-key
# GEMINI_API_KEY=your-gemini-api-key
# VERTEX_ACCESS_TOKEN=your-oauth-access-token

# Optional overrides
VERTEX_API_VERSION=v1
# GEMINI_API_VERSION=v1beta
VERTEX_TIMEOUT_SECONDS=90
VERTEX_REQUEST_MIN_INTERVAL_MS=2000
VERTEX_REQUEST_JITTER_MS=0
VERTEX_MAX_RETRIES=2
VERTEX_RETRY_BACKOFF_SECONDS=6

# Model routing
VERTEX_MODEL_TEXT=gemini-2.5-pro
VERTEX_MODEL_STRUCTURED=gemini-2.5-pro
VERTEX_MODEL_RESEARCH=gemini-2.5-pro
VERTEX_MODEL_SAFETY=gemini-2.5-flash
